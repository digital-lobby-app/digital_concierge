# Supabase project credentials. Copy this file to .env and fill in real values.
# Get these from the Supabase dashboard: Settings > API.
SUPABASE_URL=
SUPABASE_ANON_KEY=

# Local Postgres connection. Format: postgresql://USER:PASSWORD@HOST:PORT/DBNAME?schema=public
# For Postgres.app on macOS: USER is your Mac username, no password.
DATABASE_URL=