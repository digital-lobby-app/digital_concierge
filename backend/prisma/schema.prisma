// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────────────────────────────────────
// Enums
// ─────────────────────────────────────────────────────────────────────────

enum Role {
  admin
  visitor // vestigial in MVP — no guest authentication
}

enum ModuleKind {
  about
  map
  guestbook
}

enum PoiCategory {
  restaurant
  sports
  attraction
  shopping
}

enum PoiSource {
  admin
  guest
}

enum ReviewType {
  map
  guestbook
}

// ─────────────────────────────────────────────────────────────────────────
// Models
// ─────────────────────────────────────────────────────────────────────────

/// The tenant. Every non-Hotel row is scoped by hotelId.
model Hotel {
  id          String   @id @default(uuid())
  slug        String   @unique
  name        String
  description String?
  address     String?
  logoUrl     String?
  latitude    Float?
  longitude   Float?
  mapZoom     Int?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  users    User[]
  settings Settings?
  modules  Module[]
  pois     Poi[]
  reviews  Review[]
  faqs     Faq[]
}

/// Hotel admin identity. One row per Supabase auth user.
model User {
  supabaseUserId String   @id
  email          String   @unique
  role           Role     @default(admin)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  hotelId String
  hotel   Hotel  @relation(fields: [hotelId], references: [id])
}

/// Per-hotel branding & presentation config. 1:1 with Hotel.
model Settings {
  id           String   @id @default(uuid())
  colorPalette String
  bgImages     String
  fontPair     String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  hotelId String @unique
  hotel   Hotel  @relation(fields: [hotelId], references: [id])
}

/// Module instance content per hotel. MVP seeds all three kinds for each hotel.
model Module {
  id        String     @id @default(uuid())
  view      ModuleKind
  position  Int
  content   Json
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  hotelId String
  hotel   Hotel  @relation(fields: [hotelId], references: [id])
}

/// Point of interest on a hotel's map. Created by admin or guest.
model Poi {
  id        String      @id @default(uuid())
  category  PoiCategory
  latitude  Float
  longitude Float
  name      String
  comment   String?
  source    PoiSource
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  hotelId String
  hotel   Hotel    @relation(fields: [hotelId], references: [id])
  reviews Review[]
}

model Faq {
  id        String   @id @default(uuid())
  question  String
  answer    String
  position  Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  hotelId String
  hotel   Hotel  @relation(fields: [hotelId], references: [id], onDelete: Cascade)

  @@index([hotelId])
}

/// Map review (tied to a POI) or guestbook entry (no POI).
model Review {
  id           String     @id @default(uuid())
  type         ReviewType
  rating       Int?
  comment      String
  reviewerName String?
  createdAt    DateTime   @default(now())

  hotelId String
  hotel   Hotel  @relation(fields: [hotelId], references: [id])

  poiId String?
  poi   Poi?    @relation(fields: [poiId], references: [id], onDelete: Cascade)
}
